# Salesforce — OAuth 2.0 Resource Owner Password Credentials Flow
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
# Append security token to password if your org requires it (concatenate, no separator)
SF_SECURITY_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CORS — comma-separated list of allowed origins. Vercel preview pattern is matched by regex.
ALLOWED_ORIGINS=http://localhost:3000

# Geopointe — geopointe__Route__c may only define Locations_1..3 in some orgs (SOQL errors if you select missing fields). Max 10.
GEOPOINTE_ROUTE_LOCATION_SLOTS=3

# Demo mode default ICL
DEMO_ICL_CODE=GAC6

# Geocoding + walking-route providers (either, both, or neither)
GOOGLE_MAPS_API_KEY=
# OpenRouteService — used for /api/geocode (provider=ors) and /api/routes/lasso
# Free tier: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=
